{
  "name": "ftml-intellisense",
  "displayName": "FTML IntelliSense",
  "description": "Autocomplete and validation for FTML (Front Template Markup Language) attributes",
  "version": "0.1.0",
  "publisher": "aleptra",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleptra/ftml-vscode"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:html"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "FTML",
      "properties": {
        "ftml.enableValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable FTML attribute validation (yellow warnings for unknown attributes)"
        }
      }
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
